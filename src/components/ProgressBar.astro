---
import {iconClass} from "../lib/icons";

interface Props {
    currentProgress: number;
    totalGoal: number;
    goalLogo: string;
    label: string;
    unit: string;
}

const {currentProgress, totalGoal, goalLogo, label, unit} = Astro.props;

const percent = Math.max(0, Math.min(100, (currentProgress / totalGoal) * 100));

/**
 * The fill paints --shadow, a light pink in BOTH themes, so the icon on it takes
 * --on-brand instead of inheriting --text — which is near-white in dark mode and
 * left the icon at 1.89:1 against the fill. 3:1 is the bar SC 1.4.11 sets for
 * graphical objects; we hold to it here even though the icon is aria-hidden.
 */
---

<div
        class="overflow-hidden bg-gray-300 rounded-full h-6 mt-4"
        role="progressbar"
        aria-label={label}
        aria-valuemin="0"
        aria-valuemax={totalGoal}
        aria-valuenow={currentProgress}
        aria-valuetext={`${currentProgress} of ${totalGoal} ${unit}`}
>
    <div
            class="progress-fill h-full bg-[var(--shadow)] text-[var(--on-brand)] rounded-full px-2 box-border flex items-center justify-end"
            style={`--progress: ${percent}%`}
    >
        <span aria-hidden="true" class={`${iconClass(goalLogo)} shrink-0 text-base`}></span>
    </div>
</div>

<style>
    .progress-fill {
        width: var(--progress);
        animation: progress-grow 1.5s ease-in-out 0.3s backwards;
    }

    @keyframes progress-grow {
        from {
            width: 0;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .progress-fill {
            animation: none;
        }
    }
</style>
