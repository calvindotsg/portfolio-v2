---
// The first class token below is load-bearing: below the md breakpoint the
// intro card's portrait and its scrim are both painted at a negative
// z-index, and this stacking context is what keeps them above this card's
// background instead of behind the page; the old perspective utility used to
// provide it accidentally.
// NB: UnoCSS scans .astro frontmatter, so never name a utility here that the
// template does not actually use — it emits a real CSS rule for a class
// nothing has. That is how the old perspective utility survived as dead CSS.
interface Props {
    title?: string;
    titleIcon?: string;
    colSpan?: string;
    rowSpan?: string;
}

const {title, titleIcon, colSpan, rowSpan} = Astro.props;
---

<div
        class={`isolate overflow-hidden bg-[var(--card-background)] shadow-lg rounded-lg p-6 border border-[var(--card-border)] hover:border-[var(--accent)] relative w-full transition-colors duration-300 ease-in-out col-span-1 ${colSpan || "md:col-span-2"} ${rowSpan || ""}`}
>
    {title && <h2 class="text-xl font-bold m-0">{titleIcon && <span class={titleIcon} aria-hidden="true"></span>} {title}</h2>}
    <slot/>
</div>
