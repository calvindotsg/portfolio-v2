---
// `isolate` (first class token below) is load-bearing: the intro card's
// portrait is z-[-1] at mobile and must stack above this card's background;
// the old perspective-1200 provided that stacking context accidentally.
interface Props {
    title?: string;
    titleIcon?: string;
    colSpan?: string;
    rowSpan?: string;
}

const {title, titleIcon, colSpan, rowSpan} = Astro.props;
---

<div
        class={`isolate overflow-hidden bg-[var(--card-background)] shadow-lg rounded-lg p-6 border border-[var(--card-border)] hover:border-[var(--accent)] relative w-full transition-colors duration-300 ease-in-out col-span-1 ${colSpan || "md:col-span-2"} ${rowSpan || ""}`}
>
    {title && <h2 class="text-xl font-bold m-0">{titleIcon && <span class={titleIcon} aria-hidden="true"></span>} {title}</h2>}
    <slot/>
</div>
