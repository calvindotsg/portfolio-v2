---
import Card from "./Card/index.astro";
import {ABOUT_ME} from "../lib/constants";
---

<Card colSpan="md:col-span-1" rowSpan="md:row-span-4 lg:row-span-3" title="About me">
    <div class="flex flex-col gap-2">
        <ul class="text-sm font-light list-disc list-inside">
            {ABOUT_ME.description.map((item) => (
                    <li>{item}</li>))}
        </ul>
    </div>
</Card>
